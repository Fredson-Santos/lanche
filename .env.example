# LANCHE MVP - Environment Variables Template
# Copy to .env and update values for your environment

# Backend (FastAPI)
# DATABASE_URL=sqlite:///./lanche.db
DATABASE_URL=postgresql://lanche_user:lanche_pass@localhost:5432/lanche_db
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Frontend (React + Vite)
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=LANCHE MVP
